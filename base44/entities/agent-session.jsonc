{
  "name": "AgentSession",
  "type": "object",
  "properties": {
    "operator_id": {
      "type": "string",
      "description": "Reference to BusOperator"
    },
    "staff_user_id": {
      "type": "string",
      "description": "Staff user email"
    },
    "branch_id": {
      "type": "string",
      "description": "Reference to OperatorBranch"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Session start time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time",
      "description": "Session end time"
    },
    "opening_cash_xaf": {
      "type": "number",
      "description": "Opening cash balance"
    }
  },
  "required": [
    "operator_id",
    "staff_user_id",
    "started_at"
  ],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "staff_user_id": "{{user.email}}"
        },
        {
          "operator_id": {
            "$in": [
              {
                "$query": {
                  "entity": "OperatorStaff",
                  "filter": {
                    "user_id": "{{user.email}}",
                    "status": "active",
                    "staff_role": "vendor_bus_operator"
                  },
                  "field": "operator_id"
                }
              }
            ]
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "staff_user_id": "{{user.email}}"
        },
        {
          "operator_id": {
            "$in": [
              {
                "$query": {
                  "entity": "OperatorStaff",
                  "filter": {
                    "user_id": "{{user.email}}",
                    "status": "active",
                    "staff_role": "vendor_bus_operator"
                  },
                  "field": "operator_id"
                }
              }
            ]
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}